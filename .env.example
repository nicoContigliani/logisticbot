# Clerk Authentication
# Get your API keys from https://dashboard.clerk.com/~/api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Clerk Webhook
# Get your webhook secret from Clerk Dashboard > Webhooks
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# MongoDB
# Get your connection string from https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eyteacher?retryWrites=true&w=majority

# Supabase
# Get your keys from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# External APIs (optional)
# Add your external API keys here for connecting to other services
# EXAMPLE_API_KEY=your_api_key_here
