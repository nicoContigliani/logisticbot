# LogisticBot Environment Variables

# Frontend Domain (Next.js)
NEXT_PUBLIC_FRONTEND_DOMAIN=http://localhost:3000

# Backend Domain (Deno)
NEXT_PUBLIC_BACKEND_DOMAIN=http://localhost:8000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/logisticbot

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxx

# Supabase (Optional)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxx
